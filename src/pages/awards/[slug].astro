---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import { AWARDS } from '../../data/awards';

export function getStaticPaths() {
  return AWARDS.map(award => ({
    params: { slug: award.slug },
    props: { award },
  }));
}

const { award } = Astro.props;
---

<Layout 
  title={`${award.title} | Awards`}
  description={award.description}
  image={award.logo}
  url={`https://protfolio-sharveswar.vercel.app/awards/${award.slug}`}
>
  <div class="min-h-screen bg-midnight-black light:bg-cream-ivory text-cream-soft light:text-midnight-black pt-32 pb-24 transition-colors duration-500">
    <div class="max-w-4xl mx-auto px-6 w-full flex flex-col items-center">
      
      <div class="w-full flex items-center justify-between mb-12">
        <a 
          href="/#awards" 
          class="group flex items-center gap-2 text-sm font-mono tracking-widest text-white/50 hover:text-white light:text-black/50 light:hover:text-black transition-colors"
        >
          <svg class="w-4 h-4 transform group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          BACK TO AWARDS
        </a>
      </div>

      <!-- Header Section -->
      <div class="text-center mb-16 space-y-4">
        <span class="inline-block text-sm font-mono tracking-[0.2em] px-3 py-1 rounded-full border border-white/10 light:border-black/10" style={`color: ${award.color}; border-color: ${award.color}40`}>
          {award.issuer}
        </span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-black font-display tracking-tight leading-tight">
          {award.title}
        </h1>
        <p class="text-lg md:text-xl text-white/60 light:text-black/60 max-w-2xl mx-auto leading-relaxed mt-6">
          {award.description}
        </p>
      </div>

      <!-- Original Certificate Image Container -->
      <div class="w-full rounded-2xl overflow-hidden border border-white/10 light:border-black/10 shadow-2xl relative bg-black/20 light:bg-white/50 backdrop-blur-sm p-4 md:p-8 flex items-center justify-center min-h-[400px]">
        {award.fullImage ? (
          <img 
            src={award.fullImage} 
            alt={`${award.title} Certificate`} 
            class="w-full h-auto max-h-[80vh] object-contain rounded-lg"
          />
        ) : (
          <div class="text-white/40 light:text-black/40 font-mono text-sm">Certificate Image Pending</div>
        )}
      </div>

      <!-- External Link (if applicable) -->
      {award.link && (
        <div class="mt-12 flex justify-center">
          <a 
            href={award.link} 
            target="_blank" 
            rel="noopener noreferrer"
            class="group relative inline-flex items-center justify-center px-8 py-4 font-mono font-bold tracking-widest text-sm text-black bg-white rounded-full overflow-hidden transition-transform hover:scale-105 active:scale-95"
          >
            <span class="relative z-10 flex items-center gap-2">
              VERIFY CREDENTIAL
              <svg class="w-4 h-4 transform group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </span>
          </a>
        </div>
      )}
      
    </div>
  </div>

  <Navbar />
</Layout>
